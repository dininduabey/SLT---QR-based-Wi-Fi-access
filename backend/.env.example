# ---------------------------------------------------------
# SLT Wi-Fi Platform — Environment Variables
# ---------------------------------------------------------
# Copy this file to .env and fill in the values.
# In mock/development mode, leave values empty to use console logging.

# === pfSense Firewall ===
# The IP/URL of your pfSense firewall (must have REST API package installed)
PFSENSE_HOST=https://192.168.1.1
# API Key from pfSense > System > API > Settings
PFSENSE_API_KEY=
# API Secret from pfSense
PFSENSE_API_SECRET=
# Captive Portal zone name configured in pfSense
PFSENSE_CP_ZONE=zone0

# === SLT SMS Gateway ===
# The HTTP endpoint provided by SLT Mobitel for sending SMS
SLT_SMS_GATEWAY_URL=
# API Key for SLT SMS Gateway authentication
SLT_SMS_API_KEY=
# Sender ID that appears on the SMS (e.g., "SLTWiFi")
SLT_SMS_SENDER_ID=SLTWiFi

# === Server ===
PORT=8080
